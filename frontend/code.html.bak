</tr>
<tr>
<td class="px-6 py-3 font-black uppercase text-white">Benishangul-Gumuz</td>
<td class="px-6 py-3 text-accent-red font-black uppercase">Critical</td>
<td class="px-6 py-3">Insurgency</td>
<td class="px-6 py-3">Active Ops</td>
</tr>
</tbody>
</table>
</div>
</section>
</section>
