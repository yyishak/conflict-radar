<!-- Regional Table Placeholder -->
<section class="bg-radar-panel border border-radar-border rounded overflow-hidden">
<div class="p-4 border-b border-radar-border bg-radar-panel/50">
<h3 class="font-bold text-xs uppercase tracking-widest text-white">Detailed Risk Metrics Comparison</h3>
</div>
<div class="overflow-x-auto">
<table class="w-full text-left text-[11px]">
<thead class="bg-radar-dark/50 text-gray-500 font-bold uppercase tracking-widest border-b border-radar-border">
<tr>
<th class="px-6 py-3">Administrative Region</th>
<th class="px-6 py-3">Risk Level</th>
<th class="px-6 py-3">Political Violence</th>
<th class="px-6 py-3">Security Presence</th>
</tr>
</thead>
<tbody class="divide-y divide-radar-border text-gray-300">
<tr>
<td class="px-6 py-3 font-black uppercase text-white">Somali Region</td>
<td class="px-6 py-3 text-accent-yellow font-bold uppercase">Elevated</td>
<td class="px-6 py-3">High</td>
