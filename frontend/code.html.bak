<!DOCTYPE html>

<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Conflict Radar - Unified Intelligence Dashboard</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1" rel="stylesheet"/>
<script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'radar-dark': '#0a0a0a',
                        'radar-panel': '#121212',
                        'radar-border': '#1f1f1f',
                        'radar-red': '#e11d48',
                        'radar-orange': '#f59e0b',
                        'radar-accent': '#ef4444',
                        'primary': '#e11d48',
                        'accent-red': '#ef4444',
                        'accent-orange': '#f97316',
                        'accent-yellow': '#eab308',
                        'accent-green': '#22c55e',
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>
<style data-purpose="layout-and-effects">
        body {
            background-color: #0a0a0a;
            color: #e5e7eb;
            overflow: hidden;
            height: 100vh;
        }

        .scanline {
            width: 100%;
            height: 100px;
            z-index: 5;
            background: linear-gradient(0deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.02) 50%, rgba(255, 255, 255, 0) 100%);
            opacity: 0.1;
            position: absolute;
            bottom: 100%;
            animation: scanline 8s linear infinite;
            pointer-events: none;
        }

        @keyframes scanline {
            0% { bottom: 100%; }
            100% { bottom: -100px; }
        }

        .hotspot {
            position: absolute;
            width: 12px;
            height: 12px;
            background-color: #ef4444;
            border-radius: 50%;
            box-shadow: 0 0 15px #ef4444, 0 0 30px #ef4444;
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.5); opacity: 0.5; }
            100% { transform: scale(1); opacity: 1; }
        }

        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: #0a0a0a;
        }
        ::-webkit-scrollbar-thumb {
            background: #333;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #e11d48;
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body class="flex flex-col h-screen font-sans selection:bg-radar-red selection:text-white">
<!-- TOP NAV -->
<header class="h-16 border-b border-radar-border flex items-center justify-between px-6 bg-radar-dark/90 backdrop-blur-md z-50 shrink-0">
<div class="flex items-center gap-4">
<div class="flex items-center gap-2">
<div class="w-8 h-8 bg-radar-red rounded flex items-center justify-center">
<svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" stroke-linecap="round" stroke-linejoin="round"></path>
</svg>
</div>
<h1 class="font-black text-xl tracking-tighter uppercase">Conflict <span class="text-radar-red">Radar</span> <span class="text-xs text-gray-500 font-normal ml-2">ETHIOPIA v2.4</span></h1>
</div>
</div>
<div class="flex items-center gap-12">
<div class="text-center">
<div class="text-2xl font-black text-radar-red leading-none">24</div>
<div class="text-[10px] uppercase tracking-widest text-gray-500 mt-1">Active Incidents</div>
</div>
<div class="text-center">
<div class="text-2xl font-black text-radar-orange leading-none">68.2</div>
<div class="text-[10px] uppercase tracking-widest text-gray-500 mt-1">Regional Tension Index</div>
</div>
<div class="text-center">
<div class="text-2xl font-black text-white leading-none">12.4K</div>
<div class="text-[10px] uppercase tracking-widest text-gray-500 mt-1">Refugee Movement (24h)</div>
</div>
</div>
<div class="flex items-center gap-4">
<div class="flex bg-radar-panel rounded border border-radar-border p-1">
<button class="px-4 py-1 text-[10px] font-bold uppercase tracking-widest bg-radar-red text-white">Unified Dashboard</button>
</div>
<button class="px-4 py-2 bg-radar-border text-xs font-bold uppercase tracking-widest hover:bg-radar-red transition-colors duration-300">Export Report</button>
</div>
</header>
<main class="flex-1 flex overflow-hidden">
<!-- LEFT SIDEBAR: Live Feed -->
<aside class="w-80 border-r border-radar-border bg-radar-dark flex flex-col z-20 shrink-0" data-purpose="live-alert-feed">
<div class="p-4 border-b border-radar-border flex justify-between items-center bg-radar-panel/50">
<h2 class="text-xs font-bold uppercase tracking-[0.2em] text-radar-red flex items-center gap-2">
<span class="w-2 h-2 bg-radar-red rounded-full animate-pulse"></span>
                Live Alert Feed
            </h2>
<span class="material-symbols-outlined text-sm text-gray-500">filter_list</span>
</div>
<div class="flex-1 overflow-y-auto p-4 space-y-4">
<div class="border-l-2 border-radar-red bg-radar-panel/30 p-3 relative group cursor-pointer hover:bg-radar-panel transition-all">
<div class="text-[10px] text-gray-500 font-mono mb-1 uppercase tracking-tighter">08:42 AM · Gondar Region</div>
<p class="text-sm leading-snug">Reported localized clashes near border zones. High tension reported among local militias.</p>
<div class="mt-2 flex gap-2">
<span class="text-[9px] bg-radar-red/20 text-radar-red px-1 rounded border border-radar-red/30 uppercase">High Risk</span>
</div>
</div>
<div class="border-l-2 border-radar-orange bg-radar-panel/30 p-3 relative group cursor-pointer hover:bg-radar-panel transition-all">
<div class="text-[10px] text-gray-500 font-mono mb-1 uppercase tracking-tighter">07:15 AM · Mekelle Area</div>
<p class="text-sm leading-snug">Logistics convoy delayed at major checkpoint. Non-hostile standoff reported.</p>
<div class="mt-2 flex gap-2">
<span class="text-[9px] bg-radar-orange/20 text-radar-orange px-1 rounded border border-radar-orange/30 uppercase">Medium</span>
</div>
</div>
<div class="border-l-2 border-gray-600 bg-radar-panel/30 p-3 relative group cursor-pointer hover:bg-radar-panel transition-all">
<div class="text-[10px] text-gray-500 font-mono mb-1 uppercase tracking-tighter">05:30 AM · Wollega</div>
<p class="text-sm leading-snug">Unconfirmed reports of troop movement westward. Intelligence verifying satellite data.</p>
<div class="mt-2 flex gap-2">
<span class="text-[9px] bg-gray-700 text-gray-300 px-1 rounded uppercase">Observation</span>
</div>
</div>
<div class="border-l-2 border-radar-red bg-radar-panel/30 p-3 relative group cursor-pointer hover:bg-radar-panel transition-all">
<div class="text-[10px] text-gray-500 font-mono mb-1 uppercase tracking-tighter">03:10 AM · Amhara Region</div>
<p class="text-sm leading-snug">Internet connectivity disruptions reported in urban centers. Potential pre-emptive measure.</p>
<div class="mt-2 flex gap-2">
<span class="text-[9px] bg-radar-red/20 text-radar-red px-1 rounded border border-radar-red/30 uppercase">Critical</span>
</div>
</div>
</div>
</aside>
<!-- CENTER CONTENT: Map + Risk Analysis -->
<div class="flex-1 overflow-y-auto bg-[#050505] relative flex flex-col">
<!-- TOP SECTION: Interactive Map -->
<section class="h-[500px] relative border-b border-radar-border shrink-0" data-purpose="ethiopia-map-visual">
<div class="scanline"></div>
<div class="absolute inset-0 flex items-center justify-center pointer-events-none">
<img alt="Ethiopia 3D Map" class="max-w-[85%] max-h-[85%] object-contain mix-blend-screen opacity-40" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBUSnN_4Myo8AKQCWM8J3otl4gcDxHNtFAOuDYfMxD8AqFvBCs-17C5-sD1djr4rHwCJGD1ka5jjqKw7TsKlIf6LWivlgxtCy3IPdtcG6g4cwQ4PJJXCjFcSm3vdBpNRZJnFkHLCWIBDpfq0TwgAKsiLg_LWo7COmpIxSvO3ZfKe34Gd12vSUacZ7QcEooS5umVJtcgoy5hiAQTxzJBSsxsPynVvrj3HVqE48-sByRcBv0TSpS_fuZJqSnbi_PPEb8GMWxJpG-hmQ"/>
</div>
<!-- Hotspots -->
<div class="hotspot" style="top: 30%; left: 48%;" title="Mekelle Region"></div>
<div class="hotspot" style="top: 42%; left: 38%;" title="Gondar Region"></div>
<div class="hotspot" style="top: 58%; left: 30%;" title="Wollega Region"></div>
<div class="hotspot" style="top: 52%; left: 52%;" title="Addis Ababa"></div>
<div class="hotspot" style="top: 38%; left: 60%;" title="Afar Border Area"></div>
<!-- Overlay Labels -->
<div class="absolute top-6 left-6 z-10">
<h2 class="text-2xl font-black uppercase tracking-tight flex items-center gap-2">
                    Situational Map
                    <span class="text-[10px] bg-radar-red text-white px-2 py-0.5 rounded font-mono">LIVE FEED</span>
</h2>
<p class="text-[10px] text-gray-500 uppercase tracking-widest mt-1">Satellite Visualization Layer Alpha-4</p>
</div>
<div class="absolute bottom-6 left-6 flex flex-col gap-2 z-10">
<div class="bg-radar-panel/80 border border-radar-border p-3 backdrop-blur-md">
<h4 class="text-[10px] uppercase tracking-widest text-gray-500 mb-2 font-bold">Map Layers</h4>
<div class="flex flex-col gap-2">
<label class="flex items-center gap-2 cursor-pointer">
<input checked="" class="w-3 h-3 bg-radar-dark border-radar-border text-radar-red focus:ring-0" type="checkbox"/>
<span class="text-[10px] uppercase font-bold text-gray-300">Active Conflict Zones</span>
</label>
<label class="flex items-center gap-2 cursor-pointer">
<input checked="" class="w-3 h-3 bg-radar-dark border-radar-border text-radar-red focus:ring-0" type="checkbox"/>
<span class="text-[10px] uppercase font-bold text-gray-300">Troop Movements</span>
</label>
</div>
</div>
</div>
<div class="absolute top-6 right-6 flex gap-2 z-10">
<button class="w-10 h-10 bg-radar-panel/80 border border-radar-border flex items-center justify-center text-white hover:bg-radar-border transition-colors">
<span class="material-symbols-outlined text-sm">add</span>
</button>
<button class="w-10 h-10 bg-radar-panel/80 border border-radar-border flex items-center justify-center text-white hover:bg-radar-border transition-colors">
<span class="material-symbols-outlined text-sm">remove</span>
</button>
</div>
</section>
<!-- BOTTOM SECTION: Risk Analysis & Metrics -->
<section class="p-6 space-y-8" data-purpose="risk-analysis-view">
<!-- Header for detailed section -->
<div class="flex items-center justify-between border-b border-radar-border pb-4">
<h3 class="text-xl font-black uppercase tracking-tighter">Regional Risk Intelligence</h3>
<div class="flex gap-4 items-center">
<span class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">Data refreshed 14m ago</span>
<button class="text-radar-red text-[10px] font-bold uppercase tracking-widest hover:underline">Full Dataset</button>
</div>
</div>
<!-- National Incident Trend Chart (Combined from Screen 4) -->
<div class="bg-radar-panel border border-radar-border rounded p-6">
<div class="flex items-center justify-between mb-6">
<div>
<h3 class="font-bold text-sm uppercase tracking-widest text-white">National Incident Trend</h3>
<p class="text-[10px] text-gray-500 uppercase tracking-tighter">Cumulative violent events (30 Days)</p>
</div>
<div class="flex items-center gap-4">
<div class="flex items-center gap-2">
<span class="w-2 h-2 bg-radar-red rounded-full"></span>
