<path d="M0,80 Q50,60 100,70 T200,40 T300,50 T400,20 T500,45 T600,15 T700,30 T800,10 T900,25 T1000,5" fill="none" stroke="#e11d48" stroke-width="4"></path>
</svg>
</div>
<div class="flex-1 bg-radar-red/10 h-[30%]"></div>
<div class="flex-1 bg-radar-red/10 h-[45%]"></div>
<div class="flex-1 bg-radar-red/10 h-[35%]"></div>
<div class="flex-1 bg-radar-red/10 h-[60%]"></div>
<div class="flex-1 bg-radar-red/10 h-[50%]"></div>
<div class="flex-1 bg-radar-red/20 h-[75%]"></div>
<div class="flex-1 bg-radar-red/20 h-[65%]"></div>
<div class="flex-1 bg-radar-red/40 h-[90%]"></div>
<div class="flex-1 bg-radar-red/40 h-[80%]"></div>
<div class="flex-1 bg-radar-red h-full"></div>
</div>
<div class="flex justify-between mt-2 text-[10px] font-bold text-gray-500 uppercase tracking-widest">
<span>30 Days Ago</span>
<span>Today</span>
</div>
</div>
