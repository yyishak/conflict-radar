<span class="w-2 h-2 bg-gray-600 rounded-full"></span>
<span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest">Protests</span>
</div>
</div>
</div>
<div class="h-32 w-full flex items-end gap-1 relative overflow-hidden">
<div class="absolute inset-0 flex items-end opacity-20 pointer-events-none">
